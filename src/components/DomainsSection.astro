---
const domains = [
  {
    title: "Design Interior",
    desc: "Învață să configurezi spații ergonomice și estetice. Cursul acoperă bazele designului, teoria culorilor, studiul luminii și utilizarea programelor CAD pentru modelare 3D.",
    href: "/cursuri/design-interior",
    icon: `<svg class="size-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>`
  },
  {
    title: "Imprimare 3D",
    desc: "Descoperă procesul complet de fabricare digitală. De la configurarea imprimantei (FDM și SLA) și alegerea materialelor (PLA, PETG, rășini), până la slicing și finisare fizică.",
    href: "/cursuri/imprimare-3d",
    icon: `<svg class="size-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" /></svg>`
  },
  {
    title: "ECDL",
    desc: "Obține certificarea standard pentru utilizarea calculatorului, recunoscută internațional. Pregătire intensivă pentru modulele de baze de date, calcul tabelar, securitate și colaborare online.",
    href: "/cursuri/ecdl",
    icon: `<svg class="size-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" /></svg>`
  },
  {
    title: "Design de produs",
    desc: "Transformă ideile conceptuale în obiecte funcționale. Înveți metodologia designului de produs, ergonomie, randare realistă și tehnici de testare a prototipurilor de laborator.",
    href: "/cursuri/design-de-produs",
    icon: `<svg class="size-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122l9.37-9.37m0 0l-1.01-1.01a2.25 2.25 0 00-3.182 0l-10.01 10.01a2.25 2.25 0 00-.596 1.006l-.73 2.922a.75.75 0 00.916.916l2.922-.73a2.25 2.25 0 001.006-.596l10.01-10.01a2.25 2.25 0 000-3.182l-1.01-1.01m9.37 9.37l-1.01-1.01" /></svg>`
  },
  {
    title: "Ateliere creative",
    desc: "Dezvoltare practică dedicată copiilor și adolescenților. Introducere în robotică prin circuite electronice simple, microcontrolere Arduino și elemente de fabricație digitală distractivă.",
    href: "/cursuri/ateliere-creative",
    icon: `<svg class="size-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`
  }
];
---

<section id="domenii" class="relative py-24 md:py-32 bg-muted/30">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-3xl mb-16 md:mb-20">
      <span class="inline-block text-xs font-semibold tracking-wider text-brand uppercase mb-3">
        Ce poți studia
      </span>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground text-balance">
        Domeniile noastre principale de studiu
      </h2>
      <p class="mt-4 text-base md:text-lg text-muted-foreground">
        De la primele noțiuni de competențe digitale, la proiectarea tridimensională și materializarea prototipurilor fizice în laboratorul nostru digital.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {domains.map((dom) => (
        <a
          href={dom.href}
          class="group relative flex flex-col justify-between rounded-2xl border border-border/40 bg-background p-6 lg:p-8 hover:border-brand/40 hover:shadow-lg hover:shadow-brand/[0.02] transition-all duration-300 hover:scale-[1.01]"
        >
          <div class="absolute top-0 right-0 h-[2px] w-0 bg-brand rounded-tr-2xl group-hover:w-16 transition-all duration-300"></div>

          <div>
            <div class="size-10 rounded-lg bg-brand/5 border border-brand/10 flex items-center justify-center mb-6" set:html={dom.icon}></div>

            <h3 class="text-xl font-semibold text-foreground mb-3 group-hover:text-brand transition-colors">
              {dom.title}
            </h3>

            <p class="text-sm text-muted-foreground leading-relaxed">
              {dom.desc}
            </p>
          </div>

          <div class="flex items-center gap-1.5 text-xs font-semibold text-brand mt-8 pt-4 border-t border-border/20">
            Află detalii
            <svg class="size-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
