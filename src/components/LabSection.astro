---
---

<section id="laborator" class="relative py-24 md:py-32 overflow-hidden" style="background: #111111;">

  {/* Subtle diagonal texture */}
  <div class="lab-grain absolute inset-0 -z-10 opacity-[0.02]"></div>

  {/* Ambient golden glow — right edge */}
  <div class="absolute top-1/2 right-0 -translate-y-1/2 -z-10 w-[350px] h-[350px] rounded-full blur-[100px] pointer-events-none opacity-[0.09]"
       style="background: #B8A22A;"></div>

  {/* Ambient green glow — left edge */}
  <div class="absolute bottom-0 left-0 -z-10 w-[250px] h-[250px] rounded-full blur-[80px] pointer-events-none opacity-[0.05]"
       style="background: #6D7E53;"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

      {/* ── Left: Image ── */}
      <div class="lg:col-span-5 relative">
        <div class="relative aspect-[4/3] lg:aspect-[4/5] rounded-2xl overflow-hidden group"
             style="border: 1px solid rgba(184,162,42,0.18); box-shadow: 0 20px 70px rgba(0,0,0,0.55);">
          <img
            src="https://images.unsplash.com/photo-1615840287214-7fe58a8b668f?auto=format&fit=crop&w=800&q=85"
            alt="Imprimare 3D profesională la Laboratorul Digital BlankSpace"
            class="absolute inset-0 size-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
          {/* Dark cinematic gradient */}
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(17,17,17,0.65) 0%, rgba(17,17,17,0.1) 50%, transparent 100%);"></div>

          {/* Corner accent — top left */}
          <div class="absolute top-0 left-0 w-12 h-[2px]" style="background: #B8A22A;"></div>
          <div class="absolute top-0 left-0 w-[2px] h-12" style="background: #B8A22A;"></div>

          {/* Status badge */}
          <div class="absolute bottom-5 left-5">
            <div class="text-[10px] font-mono px-3 py-2 rounded-lg"
                 style="background: rgba(17,17,17,0.88); color: #B8A22A; border: 1px solid rgba(184,162,42,0.25); backdrop-filter: blur(10px); letter-spacing: 0.06em;">
              ◉ Echipament FDM în producție
            </div>
          </div>
        </div>

        {/* Floating stat card */}
        <div class="absolute -top-5 -right-4 hidden lg:block">
          <div class="rounded-xl px-4 py-3" style="background: rgba(26,26,26,0.95); border: 1px solid rgba(184,162,42,0.2); backdrop-filter: blur(12px);">
            <div class="text-xs font-semibold" style="color: #B8A22A;">15+ echipamente</div>
            <div class="text-[11px] mt-0.5" style="color: #5A5A5A;">active în laborator</div>
          </div>
        </div>
      </div>

      {/* ── Right: Content ── */}
      <div class="lg:col-span-7 space-y-8">
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <span class="inline-block w-8 h-[2px]" style="background: #B8A22A;"></span>
            <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: #B8A22A;">
              Dotări de ultimă generație
            </span>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-balance leading-tight" style="color: #F4F4F4; font-family: 'Playfair Display', Georgia, serif;">
            Laboratorul Digital BlankSpace
          </h2>
          <p class="text-base md:text-lg leading-relaxed" style="color: #8A8A8A;">
            Spațiul nostru integrează echipamente moderne de fabricare rapidă. Cursanții văd cum ideea lor digitală devine un prototip fizic palpabil, în câteva ore.
          </p>
        </div>

        {/* Capabilities grid */}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            {
              title: "Imprimare FDM & SLA",
              desc: "Filamente tehnice (PLA, PETG, ASA) și rășini pentru detalii de mare rezoluție.",
              icon: `<svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25" /></svg>`
            },
            {
              title: "Debitare Laser & CNC",
              desc: "Tăiere și gravură pe lemn, acrilic și plăci compozite cu mare precizie.",
              icon: `<svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122l9.37-9.37m0 0l-1.01-1.01a2.25 2.25 0 00-3.182 0l-10.01 10.01a2.25 2.25 0 00-.596 1.006l-.73 2.922a.75.75 0 00.916.916l2.922-.73a2.25 2.25 0 001.006-.596l10.01-10.01a2.25 2.25 0 000-3.182l-1.01-1.01" /></svg>`
            },
            {
              title: "Electronică & IoT",
              desc: "Stații de lipit, instrumente de măsură și module Arduino/ESP32.",
              icon: `<svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z" /></svg>`
            },
            {
              title: "Design Workstations",
              desc: "Calculatoare cu software CAD, slicing profesional și suita Adobe.",
              icon: `<svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" /></svg>`
            }
          ].map(card => (
            <div class="lab-card rounded-xl p-5 space-y-3 transition-all duration-300 cursor-default"
                 style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);"
                 onmouseover="this.style.borderColor='rgba(184,162,42,0.28)'; this.style.background='rgba(184,162,42,0.04)';"
                 onmouseout="this.style.borderColor='rgba(255,255,255,0.07)'; this.style.background='rgba(255,255,255,0.03)';">
              <div class="size-9 rounded-lg flex items-center justify-center"
                   style="background: rgba(184,162,42,0.1); color: #B8A22A;"
                   set:html={card.icon}>
              </div>
              <h4 class="font-semibold text-sm" style="color: #F4F4F4;">{card.title}</h4>
              <p class="text-xs leading-normal" style="color: #6A6A6A;">{card.desc}</p>
            </div>
          ))}
        </div>

        <div class="pt-2">
          <a
            href="/contact"
            id="lab-cta-btn"
            class="inline-flex h-11 items-center justify-center rounded-lg px-6 text-sm font-semibold transition-all hover:scale-[1.02] active:scale-[0.98]"
            style="background: #B8A22A; color: #111111; box-shadow: 0 4px 20px rgba(184,162,42,0.28);"
          >
            Programează o vizită în laborator
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .lab-grain {
    background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='40' height='40'%3E%3Cg fill='%23fff' fill-opacity='1'%3E%3Ccircle cx='0' cy='0' r='1'/%3E%3Ccircle cx='20' cy='20' r='1'/%3E%3C/g%3E%3C/svg%3E");
    background-repeat: repeat;
  }
</style>
