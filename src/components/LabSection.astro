---
---

<section id="laborator" class="relative py-24 md:py-32 bg-background overflow-hidden">
  {/* Ambient background glow */}
  <div class="absolute right-0 top-1/2 -translate-y-1/2 -z-10 w-[600px] h-[600px] bg-brand/5 rounded-full blur-[160px] pointer-events-none"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      {/* Left side: Premium Image Showcase of a 3D Printer */}
      <div class="lg:col-span-5 relative aspect-[4/3] lg:aspect-[4/5] rounded-2xl border border-border/40 overflow-hidden shadow-md group">
        <img 
          src="https://images.unsplash.com/photo-1615840287214-7fe58a8b668f?auto=format&fit=crop&w=800&q=80" 
          alt="Imprimare 3D la BlankSpace" 
          class="absolute inset-0 size-full object-cover group-hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-background/25 to-transparent"></div>
        <div class="absolute bottom-4 left-4 text-[10px] font-mono text-white bg-black/50 px-2 py-0.5 rounded backdrop-blur-xs">
          Echipament FDM în producție
        </div>
      </div>

      {/* Right side: Title, Description, and Grid */}
      <div class="lg:col-span-7 space-y-8">
        <div class="space-y-4">
          <span class="inline-block text-xs font-semibold tracking-wider text-brand uppercase">
            Dotări de ultimă generație
          </span>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground text-balance leading-tight">
            Laboratorul Digital BlankSpace
          </h2>
          <p class="text-base md:text-lg text-muted-foreground leading-relaxed">
            Spațiul nostru integrează echipamente moderne de fabricare rapidă, permițându-le cursanților să vadă cum ideea lor digitală devine un prototip fizic palpabil, în câteva ore.
          </p>
        </div>
        
        {/* 2x2 Grid of capabilities */}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="rounded-xl border border-border/40 bg-muted/20 p-5 space-y-2.5 hover:border-brand/30 transition-all duration-300">
            <div class="size-8 rounded-lg bg-brand/5 border border-brand/10 flex items-center justify-center">
              <svg class="size-4.5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25" />
              </svg>
            </div>
            <h4 class="font-semibold text-foreground text-sm">Imprimare FDM & SLA</h4>
            <p class="text-xs text-muted-foreground leading-normal">
              Filamente tehnice (PLA, PETG, ASA) și rășini pentru detalii de mare rezoluție.
            </p>
          </div>
          
          <div class="rounded-xl border border-border/40 bg-muted/20 p-5 space-y-2.5 hover:border-brand/30 transition-all duration-300">
            <div class="size-8 rounded-lg bg-brand/5 border border-brand/10 flex items-center justify-center">
              <svg class="size-4.5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122l9.37-9.37m0 0l-1.01-1.01a2.25 2.25 0 00-3.182 0l-10.01 10.01a2.25 2.25 0 00-.596 1.006l-.73 2.922a.75.75 0 00.916.916l2.922-.73a2.25 2.25 0 001.006-.596l10.01-10.01a2.25 2.25 0 000-3.182l-1.01-1.01" />
              </svg>
            </div>
            <h4 class="font-semibold text-foreground text-sm">Debitator Laser & CNC</h4>
            <p class="text-xs text-muted-foreground leading-normal">
              Tăiere și gravură fină pe lemn, acrilic și plăci compozite cu mare precizie.
            </p>
          </div>

          <div class="rounded-xl border border-border/40 bg-muted/20 p-5 space-y-2.5 hover:border-brand/30 transition-all duration-300">
            <div class="size-8 rounded-lg bg-brand/5 border border-brand/10 flex items-center justify-center">
              <svg class="size-4.5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z" />
              </svg>
            </div>
            <h4 class="font-semibold text-foreground text-sm">Electronică & IoT</h4>
            <p class="text-xs text-muted-foreground leading-normal">
              Stații de lipit digitale, instrumente de măsură și module microcontroler Arduino/ESP32.
            </p>
          </div>

          <div class="rounded-xl border border-border/40 bg-muted/20 p-5 space-y-2.5 hover:border-brand/30 transition-all duration-300">
            <div class="size-8 rounded-lg bg-brand/5 border border-brand/10 flex items-center justify-center">
              <svg class="size-4.5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
              </svg>
            </div>
            <h4 class="font-semibold text-foreground text-sm">Design Workstations</h4>
            <p class="text-xs text-muted-foreground leading-normal">
              Calculatoare performante echipate cu software CAD, slicing și suita Adobe.
            </p>
          </div>
        </div>
        
        <div class="pt-2">
          <a
            href="/contact"
            class="inline-flex h-10 items-center justify-center rounded-lg bg-foreground px-5 text-sm font-medium text-background hover:bg-foreground/90 transition-colors cursor-pointer"
          >
            Programează o vizită în laborator
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
