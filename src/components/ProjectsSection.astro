---
const projects = [
  {
    title: "Machetă Urbană Modulară",
    course: "Design Interior / Imprimare 3D",
    desc: "Un model detaliat la scară al unui cartier rezidențial sustenabil. Structurile clădirilor au fost debitate cu laser din acril și lemn de tei, iar fațadele complexe au fost printate 3D.",
    author: "Grupa 3 de Cursanți",
    specs: ["Debitare Laser", "Printare 3D PLA", "MDF"],
    image: "https://images.unsplash.com/photo-1503387873255-3a4a2345e650?auto=format&fit=crop&w=600&q=80"
  },
  {
    title: "Scaun Birchwood Eco-Design",
    course: "Design de produs",
    desc: "Un scaun minimalist asamblat exclusiv prin îmbinări de tip puzzle, fără șuruburi sau adezivi. Piesa a fost proiectată digital și debitată direct pe CNC din placaj de mesteacăn.",
    author: "Proiect Individual de Absolvire",
    specs: ["Frezare CNC", "Mesteacăn 18mm", "Finisaj Ulei"],
    image: "https://images.unsplash.com/photo-1567538096630-e0c55bd6374c?auto=format&fit=crop&w=600&q=80"
  },
  {
    title: "Sistem IoT de Monitorizare Mediu",
    course: "Ateliere Creative / IoT",
    desc: "O stație completă pentru monitorizarea aerului și temperaturii din hub. Sistemul folosește un microcontroler ESP32, integrat într-o carcasă proiectată și printată 3D în laborator.",
    author: "Atelier Proiecte Speciale",
    specs: ["ESP32", "Senzori Mediu", "Carcasă PETG"],
    image: "https://images.unsplash.com/photo-1555664424-778a1e5e1b48?auto=format&fit=crop&w=600&q=80"
  }
];
---

<section id="proiecte" class="relative py-24 md:py-32 bg-background">
  <div class="mx-auto max-w-7xl px-6">

    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 md:mb-20 gap-6">
      <div class="max-w-2xl">
        <span class="inline-block text-xs font-semibold tracking-wider text-brand uppercase mb-3">
          Rezultate tangibile
        </span>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          Proiecte realizate în spațiul nostru
        </h2>
        <p class="mt-4 text-base md:text-lg text-muted-foreground">
          O mică mostră din lucrările realizate de cursanți și membrii laboratorului. Ideile devin realitate atunci când ai acces la instrumentele potrivite.
        </p>
      </div>
      <div>
        <a
          href="/proiecte"
          class="inline-flex items-center gap-1 text-sm font-semibold text-brand hover:text-brand/80 transition-colors group"
        >
          Explorează tot portofoliul
          <svg class="size-4 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((proj, idx) => (
        <article class="group flex flex-col justify-between overflow-hidden rounded-2xl border border-border/40 bg-background hover:border-brand/30 hover:shadow-xl hover:shadow-brand/[0.01] transition-all duration-300 flex-1">
          <div class="aspect-[16/10] border-b border-border/40 relative overflow-hidden">
            <img
              src={proj.image}
              alt={proj.title}
              class="absolute inset-0 size-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
            <div class="absolute top-4 left-4 right-4 flex items-center justify-between z-10">
              <span class="text-[10px] font-semibold uppercase tracking-wider bg-black/75 text-white px-2.5 py-0.5 rounded-full border border-white/10 backdrop-blur-sm">
                {proj.course}
              </span>
              <span class="text-[10px] font-mono text-white/90">#{idx + 104}</span>
            </div>
            <div class="absolute bottom-4 left-4 right-4 flex justify-between items-center z-10 text-[10px] text-white/95 font-mono bg-black/60 px-2 py-1 rounded border border-white/10 backdrop-blur-sm">
              <span>Autor: {proj.author}</span>
            </div>
          </div>

          <div class="p-6 md:p-8 flex flex-col justify-between flex-grow space-y-6">
            <div>
              <h3 class="text-xl font-semibold text-foreground group-hover:text-brand transition-colors mb-3">
                {proj.title}
              </h3>
              <p class="text-sm text-muted-foreground leading-relaxed">
                {proj.desc}
              </p>
            </div>
            <div class="flex flex-wrap gap-1.5 pt-4 border-t border-border/20">
              {proj.specs.map((spec) => (
                <span class="text-[11px] font-medium text-muted-foreground bg-muted px-2 py-0.5 rounded-md">
                  {spec}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
