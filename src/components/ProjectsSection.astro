---
const projects = [
  {
    title: "Machetă Urbană Modulară",
    course: "Design Interior / Imprimare 3D",
    desc: "Un model detaliat la scară al unui cartier rezidențial sustenabil. Structurile clădirilor au fost debitate cu laser din acril și lemn de tei, iar fațadele complexe au fost printate 3D.",
    author: "Grupa 3 de Cursanți",
    specs: ["Debitare Laser", "Printare 3D PLA", "MDF"],
    image: "https://images.unsplash.com/photo-1503387873255-3a4a2345e650?auto=format&fit=crop&w=600&q=80"
  },
  {
    title: "Scaun Birchwood Eco-Design",
    course: "Design de produs",
    desc: "Un scaun minimalist asamblat exclusiv prin îmbinări puzzle, fără șuruburi sau adezivi. Proiectat digital și debitat direct pe CNC din placaj de mesteacăn.",
    author: "Proiect Individual de Absolvire",
    specs: ["Frezare CNC", "Mesteacăn 18mm", "Finisaj Ulei"],
    image: "https://images.unsplash.com/photo-1567538096630-e0c55bd6374c?auto=format&fit=crop&w=600&q=80"
  },
  {
    title: "Sistem IoT de Monitorizare Mediu",
    course: "Ateliere Creative / IoT",
    desc: "Stație completă pentru monitorizarea aerului și temperaturii. Sistem ESP32, integrat într-o carcasă proiectată și printată 3D în laboratorul nostru.",
    author: "Atelier Proiecte Speciale",
    specs: ["ESP32", "Senzori Mediu", "Carcasă PETG"],
    image: "https://images.unsplash.com/photo-1555664424-778a1e5e1b48?auto=format&fit=crop&w=600&q=80"
  }
];
---

<section id="proiecte" class="relative py-24 md:py-32" style="background: #FFFFFF; border-top: 1px solid #D9D6D1;">
  <div class="mx-auto max-w-7xl px-6">

    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 md:mb-20 gap-6">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 mb-5">
          <span class="inline-block w-8 h-[2px]" style="background: #B8A22A;"></span>
          <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: #B8A22A;">
            Rezultate tangibile
          </span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight" style="color: #111111; font-family: 'Playfair Display', Georgia, serif;">
          Proiecte realizate în spațiul nostru
        </h2>
        <p class="mt-4 text-base md:text-lg leading-relaxed" style="color: #5A5A5A;">
          O mostră din lucrările cursanților și membrilor laboratorului. Ideile devin realitate cu instrumentele potrivite.
        </p>
      </div>
      <div>
        <a
          href="/proiecte"
          class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors group"
          style="color: #B8A22A;"
          onmouseover="this.style.opacity='0.75';"
          onmouseout="this.style.opacity='1';"
        >
          Explorează tot portofoliul
          <svg class="size-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7">
      {projects.map((proj, idx) => (
        <article
          id={`project-card-${idx}`}
          class="group flex flex-col overflow-hidden rounded-2xl transition-all duration-300"
          style="background: #F4F4F4; border: 1px solid #D9D6D1;"
          onmouseover="this.style.boxShadow='0 16px 50px rgba(0,0,0,0.09)'; this.style.borderColor='rgba(184,162,42,0.3)'; this.style.transform='translateY(-3px)';"
          onmouseout="this.style.boxShadow='none'; this.style.borderColor='#D9D6D1'; this.style.transform='translateY(0)';"
        >
          {/* Image container */}
          <div class="aspect-[16/10] relative overflow-hidden" style="border-bottom: 1px solid #D9D6D1;">
            <img
              src={proj.image}
              alt={proj.title}
              class="absolute inset-0 size-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(17,17,17,0.65) 0%, transparent 55%);"></div>

            {/* Course badge */}
            <div class="absolute top-4 left-4">
              <span class="text-[10px] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full"
                    style="background: rgba(17,17,17,0.82); color: #B8A22A; border: 1px solid rgba(184,162,42,0.3); backdrop-filter: blur(8px);">
                {proj.course}
              </span>
            </div>

            {/* Author badge */}
            <div class="absolute bottom-4 left-4 right-4">
              <div class="text-[10px] font-mono px-2 py-1 rounded inline-block"
                   style="background: rgba(17,17,17,0.72); color: rgba(244,244,244,0.85); backdrop-filter: blur(4px);">
                {proj.author}
              </div>
            </div>
          </div>

          {/* Content */}
          <div class="p-6 flex flex-col flex-grow space-y-3">
            <h3 class="text-lg font-semibold transition-colors duration-200 group-hover:text-[#B8A22A]" style="color: #111111;">
              {proj.title}
            </h3>
            <p class="text-sm leading-relaxed flex-grow" style="color: #5A5A5A;">
              {proj.desc}
            </p>
            <div class="flex flex-wrap gap-1.5 pt-4" style="border-top: 1px solid #D9D6D1;">
              {proj.specs.map((spec) => (
                <span class="text-[11px] font-medium px-2.5 py-1 rounded-md"
                      style="background: #E8E5E0; color: #5A5A5A;">
                  {spec}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
