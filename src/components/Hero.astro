---
---

<section class="relative overflow-hidden pt-20 pb-24 md:pt-32 md:pb-36 bg-background">
  {/* Background patterns */}
  <div class="absolute inset-0 -z-10 bg-[linear-gradient(to_right,rgba(109,93,246,0.02)_1px,transparent_1px),linear-gradient(to_bottom,rgba(109,93,246,0.02)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>
  
  {/* Violet glow */}
  <div class="absolute top-0 left-1/2 -translate-x-1/2 -z-10 w-[800px] h-[350px] bg-brand/10 rounded-full blur-[120px] opacity-70 dark:opacity-40"></div>

  <div class="mx-auto max-w-7xl px-6 text-center">
    {/* Minimalist Badge */}
    <div class="inline-flex items-center gap-1.5 rounded-full border border-brand/20 bg-brand/5 px-3 py-1 text-xs font-medium text-brand mb-6 animate-fade-in-up">
      <span class="size-1.5 rounded-full bg-brand animate-pulse"></span>
      Portile sunt deschise • Înscrieri sesiunea de vară 2026
    </div>

    {/* Hero Heading */}
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-foreground max-w-4xl mx-auto leading-[1.1] mb-6 animate-fade-in-up delay-100">
      Învață prin practică.<br />
      <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand via-brand/90 to-brand/60">
        Creează cu tehnologia.
      </span>
    </h1>

    {/* Subtitle */}
    <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto leading-relaxed mb-10 animate-fade-in-up delay-200">
      Cursuri și experiențe educaționale în design, tehnologie și competențe digitale pentru copii, adulți și organizații.
    </p>

    {/* Actions */}
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up delay-300">
      <a
        href="#domenii"
        class="inline-flex w-full sm:w-auto h-11 items-center justify-center rounded-lg bg-brand px-6 font-medium text-white hover:bg-brand/90 hover:scale-[1.02] active:scale-[0.98] transition-all shadow-md shadow-brand/20 group/btn cursor-pointer"
      >
        Vezi cursurile
        <svg class="ml-1.5 size-4 group-hover/btn:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
      <a
        href="#laborator"
        class="inline-flex w-full sm:w-auto h-11 items-center justify-center rounded-lg border border-border/60 bg-background/50 hover:bg-muted/60 backdrop-blur-xs px-6 font-medium text-foreground hover:scale-[1.02] active:scale-[0.98] transition-all cursor-pointer"
      >
        Descoperă laboratorul
      </a>
    </div>

    {/* Floating Minimalist Dashboard Preview */}
    <div class="relative mt-16 md:mt-20 rounded-2xl border border-border/40 bg-background/40 backdrop-blur-md p-2 shadow-2xl shadow-brand/5 max-w-5xl mx-auto overflow-hidden animate-fade-in-up delay-400">
      <div class="rounded-xl border border-border/40 bg-background/80 overflow-hidden shadow-inner aspect-[16/9] md:aspect-[2.39/1] flex flex-col">
        {/* Window controls header */}
        <div class="h-8 border-b border-border/40 bg-muted/30 px-4 flex items-center justify-between">
          <div class="flex items-center gap-1.5">
            <span class="size-2.5 rounded-full bg-border"></span>
            <span class="size-2.5 rounded-full bg-border"></span>
            <span class="size-2.5 rounded-full bg-border"></span>
          </div>
          <span class="text-xs text-muted-foreground font-mono">blankspace.ro</span>
          <div class="w-12"></div> {/* spacer */}
        </div>
        
        {/* Dummy content window showing a gorgeous representation of a digital workspace */}
        <div class="flex-1 p-6 md:p-8 flex flex-col md:flex-row gap-6 text-left items-center justify-between bg-gradient-to-br from-background via-background to-brand/5">
          <div class="space-y-4 max-w-md">
            <div class="inline-block rounded-md bg-brand/10 text-brand px-2 py-0.5 text-xs font-semibold">
              Laborator deschis
            </div>
            <h3 class="text-xl md:text-2xl font-bold tracking-tight text-foreground">
              De la idee digitală, la obiect fizic tangibil
            </h3>
            <p class="text-sm text-muted-foreground leading-relaxed">
              O combinație rară de software de design, imprimare 3D avansată, și mentorat individual pentru a aduce proiectul tău la viață.
            </p>
            <div class="flex items-center gap-3 pt-2">
              <span class="text-xs font-medium bg-muted px-2.5 py-1 rounded-md text-foreground">5 Echipamente 3D</span>
              <span class="text-xs font-medium bg-muted px-2.5 py-1 rounded-md text-foreground">2 Săli de design</span>
              <span class="text-xs font-medium bg-muted px-2.5 py-1 rounded-md text-foreground">Acces 24/7</span>
            </div>
          </div>
          
          {/* High-quality technology placeholder image */}
          <div class="relative size-48 md:size-64 rounded-xl border border-border/40 overflow-hidden shadow-lg group/visual">
            <img 
              src="https://images.unsplash.com/photo-1517059224940-d4af9eec41b7?auto=format&fit=crop&w=600&q=80" 
              alt="Digital Workspace BlankSpace" 
              class="absolute inset-0 size-full object-cover group-hover:scale-105 transition-transform duration-700" 
              loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-background/35 to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    opacity: 0;
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .delay-100 {
    animation-delay: 100ms;
  }

  .delay-200 {
    animation-delay: 200ms;
  }

  .delay-300 {
    animation-delay: 300ms;
  }

  .delay-400 {
    animation-delay: 400ms;
  }
</style>
