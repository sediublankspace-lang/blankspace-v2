---
const partners = [
  { name: "FABRICATOR", style: "font-black tracking-widest text-lg" },
  { name: "Univ. de Arhitectură & Design", style: "font-serif italic text-sm font-semibold tracking-tight" },
  { name: "STUDIO DESIGN", style: "font-light tracking-loose text-md" },
  { name: "PROTO LAB", style: "font-mono font-bold text-base" },
  { name: "ECDL Romania", style: "font-sans font-bold tracking-tight text-md" }
];
---

<section class="relative py-16 md:py-20 bg-background">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center mb-10 md:mb-12">
      <p class="text-xs font-semibold tracking-wider text-muted-foreground uppercase">
        Parteneri educaționali și tehnologici
      </p>
    </div>
    
    {/* Partners Logo Row */}
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 items-center justify-items-center opacity-50 dark:opacity-40">
      {partners.map((p) => (
        <div
          class={`text-muted-foreground hover:text-foreground transition-all duration-300 select-none cursor-default py-2 hover:opacity-100 ${p.style}`}
        >
          {p.name}
        </div>
      ))}
    </div>
  </div>
</section>
