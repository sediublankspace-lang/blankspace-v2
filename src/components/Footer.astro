---
const currentYear = new Date().getFullYear();

const courses = [
  { name: "Design Interior", href: "/cursuri/design-interior" },
  { name: "Imprimare 3D", href: "/cursuri/imprimare-3d" },
  { name: "ECDL", href: "/cursuri/ecdl" },
  { name: "Design de produs", href: "/cursuri/design-de-produs" },
  { name: "Ateliere creative", href: "/cursuri/ateliere-creative" }
];

const mainLinks = [
  { name: "Laborator Digital", href: "/laborator" },
  { name: "Proiecte", href: "/proiecte" },
  { name: "Resurse", href: "/resurse" },
  { name: "Despre noi", href: "/despre" },
  { name: "Contact", href: "/contact" }
];
---

<footer style="background: #111111; border-top: 1px solid rgba(255,255,255,0.05);" class="pt-16 md:pt-24 pb-10">
  <div class="mx-auto max-w-7xl px-6">

    {/* Top golden accent line */}
    <div class="w-full h-[1px] mb-14" style="background: linear-gradient(90deg, transparent, rgba(184,162,42,0.3), transparent);"></div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10 md:gap-12 pb-14" style="border-bottom: 1px solid rgba(255,255,255,0.06);">

      {/* Brand Column */}
      <div class="lg:col-span-4 space-y-5">
        <a href="/" class="flex items-center gap-2 group" id="footer-logo">
          <span class="text-xl font-bold tracking-tight" style="color: #F4F4F4;">
            Blank<span style="color: #B8A22A;">Space</span>
          </span>
          <div class="size-1.5 rounded-full group-hover:scale-125 transition-transform duration-300" style="background: #B8A22A;" />
        </a>

        <p class="text-sm leading-relaxed max-w-xs" style="color: #5A5A5A;">
          Spațiul tău fizic pentru design, tehnologie și competențe digitale practice. Mentorat profesionist, prototipare rapidă și comunitate creativă.
        </p>

        <p class="text-xs font-light tracking-widest" style="color: #3A3A3A; font-family: 'Playfair Display', Georgia, serif; font-style: italic;">
          Discover, create and innovate your BlankSpace.
        </p>

        {/* Social icons — placeholder */}
        <div class="flex gap-3 pt-2">
          {[
            { label: "Instagram", href: "#" },
            { label: "Facebook", href: "#" },
            { label: "LinkedIn", href: "#" }
          ].map((soc) => (
            <a
              href={soc.href}
              class="size-8 rounded-lg flex items-center justify-center text-xs font-bold transition-all duration-200"
              style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: #5A5A5A;"
              aria-label={soc.label}
              onmouseover="this.style.borderColor='rgba(184,162,42,0.4)'; this.style.color='#B8A22A'; this.style.background='rgba(184,162,42,0.06)';"
              onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'; this.style.color='#5A5A5A'; this.style.background='rgba(255,255,255,0.04)';"
            >
              {soc.label[0]}
            </a>
          ))}
        </div>
      </div>

      {/* Courses Column */}
      <div class="lg:col-span-3 space-y-4">
        <h4 class="text-[10px] font-semibold tracking-[0.2em] uppercase" style="color: #4A4A4A;">Programe</h4>
        <ul class="space-y-2.5">
          {courses.map((c) => (
            <li>
              <a
                href={c.href}
                class="text-sm transition-colors"
                style="color: #3A3A3A;"
                onmouseover="this.style.color='#B8A22A';"
                onmouseout="this.style.color='#3A3A3A';"
              >
                {c.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Links Column */}
      <div class="lg:col-span-2 space-y-4">
        <h4 class="text-[10px] font-semibold tracking-[0.2em] uppercase" style="color: #4A4A4A;">Companie</h4>
        <ul class="space-y-2.5">
          {mainLinks.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-sm transition-colors"
                style="color: #3A3A3A;"
                onmouseover="this.style.color='#B8A22A';"
                onmouseout="this.style.color='#3A3A3A';"
              >
                {l.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Contact Column */}
      <div class="lg:col-span-3 space-y-4">
        <h4 class="text-[10px] font-semibold tracking-[0.2em] uppercase" style="color: #4A4A4A;">Contact</h4>
        <ul class="space-y-3.5 text-sm" style="color: #3A3A3A;">
          <li class="flex items-start gap-2.5">
            <svg class="size-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: #B8A22A;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span>Strada Creativă Nr. 42, etaj 1, București</span>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: #B8A22A;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <a href="mailto:hello@blankspace.ro" class="transition-colors"
               onmouseover="this.style.color='#B8A22A';"
               onmouseout="this.style.color='inherit';">
              hello@blankspace.ro
            </a>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: #B8A22A;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.557-5.127-3.86-6.683-6.683l1.293-.97c.362-.272.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H3.75A2.25 2.25 0 001.5 4.5v2.25z" />
            </svg>
            <a href="tel:+40722123456" class="transition-colors"
               onmouseover="this.style.color='#B8A22A';"
               onmouseout="this.style.color='inherit';">
              +40 722 123 456
            </a>
          </li>
        </ul>
      </div>

    </div>

    {/* Bottom row */}
    <div class="flex flex-col sm:flex-row items-center justify-between pt-8 text-xs gap-4" style="color: #3A3A3A;">
      <div>
        &copy; {currentYear} BlankSpace. Toate drepturile rezervate.
      </div>
      <div class="flex gap-6">
        <a href="/termeni" class="transition-colors"
           onmouseover="this.style.color='#B8A22A';"
           onmouseout="this.style.color='#3A3A3A';">
          Termeni și condiții
        </a>
        <a href="/confidentialitate" class="transition-colors"
           onmouseover="this.style.color='#B8A22A';"
           onmouseout="this.style.color='#3A3A3A';">
          Politica de confidențialitate
        </a>
      </div>
    </div>
  </div>
</footer>
