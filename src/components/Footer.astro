---
const currentYear = new Date().getFullYear();

const courses = [
  { name: "Design Interior", href: "/cursuri/design-interior" },
  { name: "Imprimare 3D", href: "/cursuri/imprimare-3d" },
  { name: "ECDL", href: "/cursuri/ecdl" },
  { name: "Design de produs", href: "/cursuri/design-de-produs" },
  { name: "Ateliere creative", href: "/cursuri/ateliere-creative" }
];

const mainLinks = [
  { name: "Laborator Digital", href: "/laborator" },
  { name: "Proiecte", href: "/proiecte" },
  { name: "Resurse", href: "/resurse" },
  { name: "Despre noi", href: "/despre" },
  { name: "Contact", href: "/contact" }
];
---

<footer class="bg-background border-t border-border/40 py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10 md:gap-12 pb-12 border-b border-border/40">
      
      {/* Brand Column */}
      <div class="lg:col-span-4 space-y-4">
        <a href="/" class="flex items-center gap-2 group">
          <span class="text-xl font-bold tracking-tight text-foreground">
            Blank<span class="text-brand">Space</span>
          </span>
          <div class="size-2 rounded-full bg-brand group-hover:scale-125 transition-transform" />
        </a>
        <p class="text-sm text-muted-foreground max-w-sm leading-relaxed">
          Spațiul tău fizic pentru design, tehnologie și competențe digitale practice. Mentorat profesionist, prototipare rapidă și comunitate creativă.
        </p>
      </div>

      {/* Courses Column */}
      <div class="lg:col-span-3 space-y-4">
        <h4 class="text-sm font-semibold text-foreground tracking-wider uppercase">Programe</h4>
        <ul class="space-y-2.5">
          {courses.map((c) => (
            <li>
              <a href={c.href} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
                {c.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Links Column */}
      <div class="lg:col-span-2 space-y-4">
        <h4 class="text-sm font-semibold text-foreground tracking-wider uppercase">Companie</h4>
        <ul class="space-y-2.5">
          {mainLinks.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
                {l.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Contact Column */}
      <div class="lg:col-span-3 space-y-4">
        <h4 class="text-sm font-semibold text-foreground tracking-wider uppercase">Contact Hub</h4>
        <ul class="space-y-2.5 text-sm text-muted-foreground">
          <li class="flex items-start gap-2">
            <svg class="size-4 text-brand mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span>Strada Creativă Nr. 42, etaj 1, București</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="size-4 text-brand shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <a href="mailto:hello@blankspace.ro" class="hover:text-foreground transition-colors">hello@blankspace.ro</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="size-4 text-brand shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.557-5.127-3.86-6.683-6.683l1.293-.97c.362-.272.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H3.75A2.25 2.25 0 001.5 4.5v2.25z" />
            </svg>
            <a href="tel:+40722123456" class="hover:text-foreground transition-colors">+40 722 123 456</a>
          </li>
        </ul>
      </div>

    </div>

    {/* Bottom Copyright Row */}
    <div class="flex flex-col sm:flex-row items-center justify-between pt-8 text-xs text-muted-foreground gap-4">
      <div>
        &copy; {currentYear} BlankSpace. Toate drepturile rezervate.
      </div>
      <div class="flex gap-6">
        <a href="/termeni" class="hover:text-foreground transition-colors">Termeni și condiții</a>
        <a href="/confidentialitate" class="hover:text-foreground transition-colors">Politica de confidențialitate</a>
      </div>
    </div>
  </div>
</footer>
