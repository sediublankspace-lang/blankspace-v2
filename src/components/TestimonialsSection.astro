---
const testimonials = [
  {
    quote: "Băiatul meu de 12 ani a participat la atelierele creative. A fost fascinat să vadă cum un obiect desenat de el pe calculator este creat fizic, strat cu strat. Dincolo de joacă, a învățat noțiuni reale de geometrie în spațiu.",
    author: "Radu Vasilescu",
    role: "Părinte",
    photo: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=120&h=120&q=80"
  },
  {
    quote: "Mentorship-ul de la cursul de Design Interior mi-a schimbat parcursul profesional. Posibilitatea de a lucra direct cu softuri CAD și de a crea machete în laborator mi-a oferit încrederea și portofoliul de care aveam nevoie.",
    author: "Elena Marin",
    role: "Freelance Designer (Absolventă)",
    photo: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=120&h=120&q=80"
  },
  {
    quote: "Am organizat un workshop privat de design de produs cu echipa noastră. Cel mai antrenant team-building: să schițezi împreună o idee, să o printezi 3D și să o asamblezi te învață extrem de multe despre colaborare.",
    author: "Mihai Stan",
    role: "Director Operațional, Tech Corp",
    photo: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=120&h=120&q=80"
  }
];
---

<section id="testimoniale" class="relative py-24 md:py-32" style="background: #F4F4F4; border-top: 1px solid #D9D6D1;">
  <div class="mx-auto max-w-7xl px-6">

    {/* Header */}
    <div class="max-w-3xl mb-16 md:mb-20">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-block w-8 h-[2px]" style="background: #B8A22A;"></span>
        <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: #B8A22A;">
          Experiențe reale
        </span>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight" style="color: #111111; font-family: 'Playfair Display', Georgia, serif;">
        Ce spun cursanții și partenerii noștri
      </h2>
      <p class="mt-4 text-base md:text-lg leading-relaxed" style="color: #5A5A5A;">
        Nu ne crede pe cuvânt. Iată părerile celor care au trecut pragul laboratorului nostru.
      </p>
    </div>

    {/* Testimonial cards */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7">
      {testimonials.map((test, idx) => (
        <div
          id={`testimonial-card-${idx}`}
          class="group flex flex-col justify-between rounded-2xl p-7 transition-all duration-300"
          style="background: #FFFFFF; border: 1px solid #D9D6D1;"
          onmouseover="this.style.boxShadow='0 8px 32px rgba(0,0,0,0.07)'; this.style.borderColor='rgba(184,162,42,0.25)';"
          onmouseout="this.style.boxShadow='none'; this.style.borderColor='#D9D6D1';"
        >
          {/* Quotation mark — editorial style */}
          <div class="mb-5">
            <svg class="size-7" viewBox="0 0 32 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0 24V14.4C0 6.4 4.8 1.6 14.4 0L16 3.2C11.2 4.8 8.8 7.2 8.8 10.4H14.4V24H0ZM17.6 24V14.4C17.6 6.4 22.4 1.6 32 0L33.6 3.2C28.8 4.8 26.4 7.2 26.4 10.4H32V24H17.6Z"
                    fill="#B8A22A" fill-opacity="0.18"/>
            </svg>
          </div>

          <p class="text-base leading-relaxed italic flex-grow mb-7" style="color: #2A2A2A;">
            „{test.quote}"
          </p>

          {/* Author */}
          <div class="flex items-center gap-3 pt-5" style="border-top: 1px solid #D9D6D1;">
            <div class="size-10 rounded-full overflow-hidden shrink-0" style="border: 2px solid rgba(184,162,42,0.3);">
              <img
                src={test.photo}
                alt={test.author}
                class="size-full object-cover"
                loading="lazy"
              />
            </div>
            <div>
              <div class="text-sm font-semibold" style="color: #111111;">{test.author}</div>
              <div class="text-xs mt-0.5" style="color: #5A5A5A;">{test.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
